{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/context-injector/session-start-inject.sh",
        "timeout": 30
      }
    ],
    "beforeShellExecution": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/shell-secrets-deny.sh",
        "timeout": 30
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "afterShellExecution": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "beforeReadFile": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "afterFileEdit": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "preToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/context-injector/subagent-context-pre-tool-use.sh",
        "matcher": "Task",
        "timeout": 30
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete",
        "timeout": 30
      }
    ],
    "postToolUse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete",
        "timeout": 30
      }
    ],
    "postToolUseFailure": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete",
        "timeout": 30
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/context-injector/main-agent-orchestrator-inject.sh",
        "timeout": 30
      },
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "preCompact": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "afterAgentResponse": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ],
    "afterAgentThought": [
      {
        "command": "${CURSOR_PLUGIN_ROOT}/hooks/transcriptor/audit.sh",
        "timeout": 30
      }
    ]
  }
}
