{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "./hooks/context-injector/session-start-inject.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./hooks/transcriptor/shell-secrets-deny.sh"
      },
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "afterShellExecution": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "beforeReadFile": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "./hooks/context-injector/subagent-context-pre-tool-use.sh",
        "matcher": "Task"
      },
      {
        "command": "./hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete"
      }
    ],
    "postToolUse": [
      {
        "command": "./hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "./hooks/transcriptor/audit.sh",
        "matcher": "Grep|Delete"
      }
    ],
    "subagentStart": [
      {
        "command": "./hooks/context-injector/subagent-context-inject.sh",
        "matcher": "advisor"
      },
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "subagentStop": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "./hooks/context-injector/main-agent-orchestrator-inject.sh"
      },
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "preCompact": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ],
    "afterAgentThought": [
      {
        "command": "./hooks/transcriptor/audit.sh"
      }
    ]
  }
}
